# ProofPlan Environment Configuration
# Copy this file to .env and customize as needed

# ChromaDB Configuration
PROOFPLAN_CHROMADB_HOST=localhost
PROOFPLAN_CHROMADB_PORT=8000

# Logging Configuration
PROOFPLAN_LOG_LEVEL=INFO
# Options: DEBUG, INFO, WARNING, ERROR

# Embedding Provider (v0.1.0: only huggingface supported)
# PROOFPLAN_EMBEDDINGS_PROVIDER=huggingface

# Model Configuration
# PROOFPLAN_EMBEDDING_MODEL=Qwen/Qwen3-Embedding-0.6B
# PROOFPLAN_EMBEDDING_DEVICE=cpu

# Indexing Configuration
# PROOFPLAN_BATCH_SIZE=100
# PROOFPLAN_PARALLEL_WORKERS=4

# Performance Tuning
# PROOFPLAN_CACHE_SIZE=1000
# PROOFPLAN_MAX_MEMORY_GB=2
